{
  "manifest_version": 3,
  "name": "NotebookLM Enhancer",
  "version": "1.1.2",
  "description": "NotebookLM 的功能增强插件，提供目录管理、高级搜索等进阶功能",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon.png",
      "48": "icons/icon.png",
      "128": "icons/icon.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://notebooklm.google.com/*"
      ],
      "css": [
        "styles/main.css"
      ],
      "js": [
        "scripts/storage.js",
        "scripts/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "https://notebooklm.google.com/*",
    "https://api.gumroad.com/*"
  ],
  "icons": {
    "16": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  }
}